# powerelf-skills 数据库凭证约定（示例）
#
# 实际凭证由 hermes 启动时从 ~/.hermes/.env 加载
# （见 /opt/git/hermes-agent/hermes_cli/main.py: load_hermes_dotenv）。
# 本文件仅为约定文档，**切勿**填入真实密码后提交（.env 已被 .gitignore 忽略）。
#
# _shared/lib/db.py 读取顺序：POWERELF_DB_*（标准）→ SRM_DB_*（旧名后备）→ 内置默认。
# 两套任设其一即可；POWERELF_DB_* 优先。历史教训：曾把密码误填进
# POWERELF_DB_HOST / POWERELF_DB_PORT 字段，导致 db.py 在 import 期 int() 崩溃，
# 整个 skill 不可用——端口字段必须是数字。

# 标准前缀（推荐）：
POWERELF_DB_HOST=127.0.0.1
POWERELF_DB_PORT=3306
POWERELF_DB_NAME=powerelf_srm_yml
POWERELF_DB_USER=root
POWERELF_DB_PASSWORD=改我_勿提交

# 旧名后备（POWERELF_DB_* 未设时回退；与 water-resources-skills 的 SL323_DB_* 同构）：
# SRM_DB_HOST=127.0.0.1
# SRM_DB_PORT=3306
# SRM_DB_NAME=powerelf_srm_yml
# SRM_DB_USER=root
# SRM_DB_PASSWORD=改我_勿提交

# === 路径配置 ===
# POWERELF_SKILLS_ROOT=部署时指向 powerelf-skills 仓库根目录
# 不设置则自动从 symlink / 相对路径推算（开发环境默认可用）
# POWERELF_SKILLS_ROOT=/home/scada/powerelf-skills
